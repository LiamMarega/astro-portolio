---
/*
  BookIntro — apertura realista del scrapbook.
  El libro está apoyado sobre un escritorio oscuro, la tapa kraft se abre
  con sombreado dinámico, dos hojas pasan y la cámara se hunde en la página
  derecha, que se funde con el hero real (mismo color de papel).
  - Se muestra una sola vez por sesión (sessionStorage).
  - Se salta con click / Escape / prefers-reduced-motion / hash en la URL.
  - El contenido de la página queda 100% accesible para crawlers sin JS.
*/
---

<!-- Gate síncrono: decide ANTES del primer paint si la intro corre. -->
<script is:inline>
  (function () {
    try {
      var seen = sessionStorage.getItem("lbIntroSeen");
      var reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!seen && !reduced && !location.hash) {
        document.documentElement.classList.add("lb-introing");
        if ("scrollRestoration" in history) history.scrollRestoration = "manual";
        window.scrollTo(0, 0);
      }
    } catch (e) {}
  })();
</script>

<div id="lbIntro" class="lb-intro" data-no-pencil role="presentation" aria-hidden="true">
  <div class="lbi-dust" aria-hidden="true">
    <span></span><span></span><span></span><span></span><span></span><span></span>
  </div>

  <div class="lbi-scene">
    <div class="lbi-shadow"></div>

    <div class="lbi-book">
      <!-- contratapa -->
      <div class="lbi-board lbi-backboard"></div>

      <!-- bloque de hojas (canto del libro) -->
      <div class="lbi-block">
        <span class="lbi-block-edge r"></span>
        <span class="lbi-block-edge b"></span>
      </div>

      <!-- página final (lo que queda a la vista tras pasar las hojas) -->
      <div class="lbi-base">
        <div class="lbi-base-inner">
          <span class="lbi-kicker">capítulo 01</span>
          <span class="lbi-hand">tu embudo<br />empieza acá&nbsp;↓</span>
          <svg class="lbi-arrow" viewBox="0 0 60 70" aria-hidden="true">
            <path d="M30 6 C 44 22, 18 34, 30 56" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
            <path d="M22 47 L 30 58 L 39 49" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
      </div>

      <!-- hoja 2 (queda debajo de la 1) -->
      <div class="lbi-sheet s2">
        <div class="lbi-face front">
          <span class="lbi-doodle">ideas sueltas, bocetos,<br />cafés de por medio…</span>
          <span class="lbi-scratch" aria-hidden="true"></span>
          <span class="lbi-shade"></span>
        </div>
        <div class="lbi-face back"><span class="lbi-shade"></span></div>
      </div>

      <!-- hoja 1 (portadilla) -->
      <div class="lbi-sheet s1">
        <div class="lbi-face front">
          <span class="lbi-mini-k">Cuaderno de conversión</span>
          <span class="lbi-mini-t">LiamDev</span>
          <span class="lbi-mini-s">vol. 1 · landings que venden</span>
          <span class="lbi-shade"></span>
        </div>
        <div class="lbi-face back"><span class="lbi-shade"></span></div>
      </div>

      <!-- tapa kraft -->
      <div class="lbi-cover">
        <div class="lbi-face front">
          <span class="lbi-elastic"></span>
          <div class="lbi-label">
            <span class="lbi-k">Cuaderno de conversión</span>
            <span class="lbi-t">LiamDev</span>
            <span class="lbi-s">vol. 1 · landings que venden</span>
          </div>
          <span class="lbi-corner tl"></span>
          <span class="lbi-corner br"></span>
          <span class="lbi-shade"></span>
        </div>
        <div class="lbi-face back">
          <span class="lbi-pocket"></span>
          <span class="lbi-shade"></span>
        </div>
        <span class="lbi-cover-edge"></span>
      </div>

      <!-- lomo -->
      <div class="lbi-spine"></div>
    </div>
  </div>

  <button class="lbi-skip" type="button">tocá para abrir →</button>
</div>

<script>
  import gsap from "gsap";

  const html = document.documentElement;
  const intro = document.getElementById("lbIntro");

  function finish(immediate = false) {
    try {
      sessionStorage.setItem("lbIntroSeen", "1");
    } catch (e) {}
    const done = () => {
      intro?.remove();
      html.classList.remove("lb-introing");
      (window as any).__lbIntroDone = true;
      window.dispatchEvent(new CustomEvent("lb:introDone"));
    };
    if (immediate || !intro) done();
    else gsap.to(intro, { opacity: 0, duration: 0.45, ease: "power1.out", onComplete: done });
  }

  if (!html.classList.contains("lb-introing") || !intro) {
    // Sin intro: avisamos igual para que el hero haga su entrada.
    (window as any).__lbIntroDone = true;
    window.dispatchEvent(new CustomEvent("lb:introDone"));
    intro?.remove();
  } else {
    window.scrollTo(0, 0);
    const q = (s: string) => intro.querySelector<HTMLElement>(s);
    const book = q(".lbi-book")!;
    const scene = q(".lbi-scene")!;
    const cover = q(".lbi-cover")!;
    const s1 = q(".lbi-sheet.s1")!;
    const s2 = q(".lbi-sheet.s2")!;
    const shadow = q(".lbi-shadow")!;
    const shades = (root: HTMLElement) => root.querySelectorAll<HTMLElement>(".lbi-shade");

    // Sombreado dinámico de una cara mientras rota.
    const shadeTo = (el: HTMLElement, v: number, d: number) =>
      gsap.to(shades(el), { opacity: v, duration: d, ease: "power1.inOut" });

    const tl = gsap.timeline({
      defaults: { ease: "power3.inOut" },
      onComplete: () => finish(),
    });

    // 0 — el libro "cae" sobre el escritorio
    tl.fromTo(
      book,
      { y: 90, z: 120, rotateX: 38, rotateZ: -7, opacity: 0 },
      { y: 0, z: 0, rotateX: 26, rotateZ: -4, opacity: 1, duration: 0.75, ease: "power2.out" },
    )
      .fromTo(shadow, { opacity: 0, scaleX: 0.55 }, { opacity: 1, scaleX: 0.9, duration: 0.75, ease: "power2.out" }, "<")
      // 1 — la tapa se abre
      .addLabel("open", "+=0.18")
      .to(cover, { rotateY: -178, duration: 1.05 }, "open")
      .to(book, { rotateZ: 0, rotateX: 16, xPercent: 24, duration: 1.05 }, "open")
      .to(shadow, { scaleX: 1.55, xPercent: 12, opacity: 0.85, duration: 1.05 }, "open")
      .add(() => {}, "open+=0.5");
    shadeTo(cover, 1, 0.5).then(() => shadeTo(cover, 0.25, 0.5));

    // 2 — pasan dos hojas
    tl.addLabel("p1", "open+=0.78")
      .to(s1, { rotateY: -176, duration: 0.7, ease: "power2.inOut" }, "p1")
      .addLabel("p2", "p1+=0.34")
      .to(s2, { rotateY: -174, duration: 0.66, ease: "power2.inOut" }, "p2")
      // 3 — zoom hacia la página derecha → se funde con el hero
      .addLabel("zoom", "p2+=0.5")
      .to(book, { rotateX: 0, duration: 0.85 }, "zoom")
      .to(scene, { scale: 3.4, xPercent: -34, yPercent: 16, duration: 0.85, ease: "power2.in" }, "zoom")
      .to(shadow, { opacity: 0, duration: 0.4 }, "zoom");

    [s1, s2].forEach((s, i) => {
      gsap.delayedCall(1.7 + i * 0.34, () => {
        shadeTo(s, 0.85, 0.3).then(() => shadeTo(s, 0, 0.3));
      });
    });

    // Saltar
    const skip = () => {
      tl.kill();
      finish();
    };
    intro.addEventListener("click", skip, { once: true });
    window.addEventListener(
      "keydown",
      (e) => {
        if (e.key === "Escape" || e.key === "Enter" || e.key === " ") skip();
      },
      { once: true },
    );
    // Failsafe por si algo bloquea la animación.
    setTimeout(() => {
      if (document.getElementById("lbIntro")) finish(true);
    }, 6500);
  }
</script>
