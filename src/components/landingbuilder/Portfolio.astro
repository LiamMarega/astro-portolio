---
const items = [
  "Desarrollo 100% a cargo mío",
  "Comunicación directa y transparente",
  "Sin intermediarios, sin excusas",
  "Cupos limitados para asegurar calidad",
  "Acompañamiento antes, durante y después",
];
const check =
  '<path d="M4 12.5l4.4 4.4L20 6" />';
const stats = [
  { ic: '<path d="M3 16s5-8 13-8 13 8 13 8-5 8-13 8S3 16 3 16z" /><circle cx="16" cy="16" r="3" />', strong: "Foco total", span: "en tu proyecto" },
  { ic: '<path d="M16 4l10 10-10 14L6 14z" /><path d="M6 14h20M16 4v24" />', strong: "Calidad premium", span: "en cada detalle" },
  { ic: '<path d="M4 26h24" /><path d="M8 22V14M14 22V8M20 22v-7M26 22v-12" /><path d="M6 10l6-4 5 3 8-5" />', strong: "Resultados que", span: "se pueden medir" },
];
---

<section id="sobre" class="block" style="padding-top:50px">
  <div class="about">
    <div class="left">
      <div class="kicker reveal">¿Por qué trabajar conmigo?</div>
      <h2 class="reveal d1" style="margin-top:16px">Detrás de cada landing<br />estoy yo.</h2>
      <ul class="reveal d2">
        {items.map((it) => (
          <li>
            <span class="ck">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={check} />
            </span>
            {it}
          </li>
        ))}
      </ul>
      <div class="signature reveal d3">Liam</div>
    </div>

    <div class="mid reveal d2">
      <div class="photo-card">
        <div class="backing"></div>
        <div class="frame">
          <img src="/images/uploads/liam.jpg" width="340" height="380" alt="Liam" loading="lazy" decoding="async" />
        </div>
        <span class="tape lg" style="top:-14px;left:40%;transform:rotate(-4deg)"></span>
        <span class="tape sm" style="bottom:-10px;right:20px;transform:rotate(8deg)"></span>
        <div class="caption">Liam · @LiammDev</div>
      </div>
    </div>

    <div class="right">
      <blockquote class="reveal">
        No busco hacer muchas landing pages. Busco hacer pocas, pero que generen
        resultados reales.
      </blockquote>
      <div class="stats reveal d2">
        {stats.map((s) => (
          <div class="it">
            <span class="ic">
              <svg viewBox="0 0 32 32" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={s.ic} />
            </span>
            <strong>{s.strong}</strong>
            <span>{s.span}</span>
          </div>
        ))}
      </div>
      <div class="note alt cupos-note reveal d3">
        <span class="tape sm" style="top:-10px;right:30px;transform:rotate(9deg)"></span>
        <span class="l">Cupos limitados</span>
        <p>Trabajo con un número reducido de proyectos cada mes para poder entregar lo mejor.</p>
      </div>
    </div>
  </div>
</section>
