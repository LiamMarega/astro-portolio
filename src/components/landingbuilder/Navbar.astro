---
const links = [
  { href: "#servicios", label: "Servicios" },
  { href: "#proceso", label: "Proceso" },
  { href: "#resultados", label: "Resultados" },
  { href: "#faq", label: "FAQ" },
  { href: "/landing-builder/articulos", label: "Artículos" },
];
---

<header class="nav" id="top">
  <span id="navProgress" class="nav-progress" aria-hidden="true"></span>
  <a class="logo" href="#top" aria-label="LiamDev — inicio">LiamDev</a>
  <nav aria-label="Navegación principal">
    <ul>
      {links.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>
  </nav>
  <a
    href="#calificar"
    class="btn btn-yellow magnet nav-cta"
    style="padding:10px 18px;font-size:11.5px"
  >
    Diagnóstico gratis
  </a>
</header>
