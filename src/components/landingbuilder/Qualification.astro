---
import BigBlob from "./BigBlob.astro";
import QualForm from "./QualForm.tsx";
---

<section id="calificar" class="block qual-block" style="padding-top:60px">
  <BigBlob
    size={460}
    parallax={0.22}
    rotate="170deg"
    flip
    style="position:absolute;left:-160px;bottom:-80px;opacity:.5;filter:blur(2px);z-index:0"
  />
  <div class="qual">
    <div class="qual-intro">
      <div class="kicker reveal">¿Calificamos?</div>
      <h2 class="reveal d1" style="margin-top:16px;font-size:clamp(30px,3.2vw,44px);line-height:1.05">
        Para dar resultados, el<br />proyecto tiene que ser<br />el indicado.
      </h2>
      <p class="reveal d2" style="margin-top:22px;max-width:400px;font-size:15px">
        Respondo pocas solicitudes porque necesito asegurar que pueda generar un
        impacto real en tu negocio. Completá este mini diagnóstico — toma 40
        segundos.
      </p>
      <div class="qual-side reveal d3">
        Sé honesto,<br />es para vos.
        <div class="qual-arrow">
          <svg viewBox="0 0 90 110" width="74" height="92" fill="none" aria-hidden="true">
            <path d="M 50 8 C 78 18, 80 48, 38 60" stroke="#b88e00" stroke-width="3.2" stroke-linecap="round" fill="none"></path>
            <path d="M 28 50 L 38 60 L 50 54" stroke="#b88e00" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
          </svg>
        </div>
      </div>
    </div>
    <div class="qf-wrap reveal d2">
      <QualForm client:visible />
    </div>
  </div>
</section>
