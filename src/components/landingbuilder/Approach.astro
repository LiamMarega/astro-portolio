---
import SketchBorder from "./SketchBorder.astro";

const bullets = [
  "Diseño y desarrollo 100% a medida (no uso plantillas)",
  "Estructura persuasiva basada en copywriting",
  "Desarrollo rápido, limpio y optimizado",
  "UX impecable en desktop y mobile",
  "Integraciones con e-mail, CRM y analíticas",
  "Mantenimiento y soporte post-lanzamiento",
];

const cards = [
  { n: "01", t: "Claridad", p: "Tu oferta se entiende al instante.", pos: "top:8%;left:8%", rot: -1.5, tape: "sm", tapePos: "top:-10px;left:18px;transform:rotate(10deg)" },
  { n: "02", t: "Conversión", p: "Cada elemento guía al siguiente paso.", pos: "top:52%;left:12%", rot: 1.5, tape: "sm", tapePos: "top:-10px;left:18px;transform:rotate(10deg)" },
  { n: "03", t: "Velocidad", p: "Cargas rápidas, mejor experiencia, más resultados.", pos: "top:16%;right:2%", rot: 1.2, tape: "sm", tapePos: "top:-10px;right:24px;transform:rotate(-6deg)" },
  { n: "04", t: "Mobile-first", p: "Perfecto en cualquier dispositivo.", pos: "top:62%;right:4%", rot: -1.0, tape: "lg", tapePos: "top:-12px;right:14px;transform:rotate(7deg)" },
];
---

<section id="servicios" class="block">
  <div class="svc">
    <div>
      <div class="kicker reveal">Lo que hago por vos</div>
      <h2 class="reveal d1" style="margin-top:16px;font-size:clamp(34px,3.8vw,52px);line-height:1.04">
        Landing pages estratégicas<br />que convierten.
      </h2>
      <ul class="bullets reveal d2">
        {bullets.map((b) => (
          <li>
            <span class="ck">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12.5l4.4 4.4L20 6" /></svg>
            </span>
            {b}
          </li>
        ))}
      </ul>
      <div class="note svc-note reveal d3">
        <span class="tape sm" style="top:-10px;left:14px;transform:rotate(-10deg)"></span>
        <span class="tape sm" style="top:-10px;right:24px;transform:rotate(8deg)"></span>
        <p>
          Todo enfocado en un solo objetivo:<br />
          <em>más oportunidades reales para tu negocio.</em>
        </p>
      </div>
    </div>

    <div class="blob-stage reveal d2">
      <div class="blob">
        <img src="/images/uploads/blob.webp" alt="" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:contain;transform:rotate(-25deg)" />
      </div>
      <svg class="svc-threads" viewBox="0 0 600 600" preserveAspectRatio="none" aria-hidden="true">
        <path d="M 200 80 Q 260 60 280 130"></path>
        <path d="M 430 130 Q 490 140 540 175"></path>
        <path d="M 200 360 Q 280 400 310 360"></path>
        <path d="M 440 360 Q 510 380 540 340"></path>
      </svg>
      {cards.map((c, i) => (
        <div
          class="card svc-card reveal"
          style={`${c.pos};transform:rotate(${c.rot}deg);transition-delay:${0.15 + i * 0.1}s`}
        >
          <SketchBorder pad={3} />
          <span class={`tape ${c.tape}`} style={c.tapePos}></span>
          <div class="top">
            <span class="n">{c.n}</span>
            <span class="dots">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true">
                <circle cx="3" cy="3" r="1" /><circle cx="11" cy="3" r="1" />
                <circle cx="3" cy="11" r="1" /><circle cx="11" cy="11" r="1" />
              </svg>
            </span>
          </div>
          <h5>{c.t}</h5>
          <p>{c.p}</p>
        </div>
      ))}
    </div>
  </div>
</section>
