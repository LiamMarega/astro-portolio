---
---

<section class="py-24 bg-background-dark relative overflow-hidden" id="approach">
  <div class="absolute inset-0 tech-grid opacity-10 pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex flex-col md:flex-row justify-between items-end mb-20 border-b border-white/10 pb-8 relative">
      <div class="relative">
        <span class="text-primary font-mono text-xs tracking-widest uppercase mb-3 block">El Proceso</span>
        <h2 class="text-4xl lg:text-5xl font-bold text-white font-display leading-tight">
          Ingeniería de <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-white">
            Conversión
          </span>
        </h2>
      </div>
      <div class="hidden md:block relative max-w-sm text-right">
        <p class="text-text-dim text-sm leading-relaxed">
          Metodología probada para transformar visitantes curiosos en clientes de alto valor.
        </p>
      </div>
    </div>

    <!-- Timeline wrapper -->
    <div class="relative">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 relative z-10">
        
        <!-- Step 1 -->
        <div class="relative group">
          <div class="mb-8 relative flex items-center">
            <div class="w-12 h-12 rounded-full border border-border-dark bg-surface-dark flex items-center justify-center text-white font-bold font-mono text-lg group-hover:border-primary group-hover:text-primary transition-colors duration-300 relative z-10 shadow-[0_0_15px_rgba(0,0,0,0.5)] group-hover:shadow-[0_0_20px_rgba(34,197,94,0.2)]">
              01
            </div>
            <div class="hidden lg:block h-[1px] w-full bg-border-dark group-hover:bg-primary/50 transition-colors duration-500 origin-left"></div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-display">Auditoría & Estrategia</h3>
          <p class="text-text-dim text-sm leading-relaxed">
            Analizamos tu negocio, tu oferta y tu cliente. No diseñamos sin saber exactamente qué problema estamos resolviendo.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative group">
          <div class="mb-8 relative flex items-center">
            <div class="w-12 h-12 rounded-full border border-border-dark bg-surface-dark flex items-center justify-center text-white font-bold font-mono text-lg group-hover:border-primary group-hover:text-primary transition-colors duration-300 relative z-10 shadow-[0_0_15px_rgba(0,0,0,0.5)] group-hover:shadow-[0_0_20px_rgba(34,197,94,0.2)]">
              02
            </div>
            <div class="hidden lg:block h-[1px] w-full bg-border-dark group-hover:bg-primary/50 transition-colors duration-500 origin-left"></div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-display">Arquitectura Persuasiva</h3>
          <p class="text-text-dim text-sm leading-relaxed">
            Estructuramos el mensaje usando fórmulas de respuesta directa para conectar, educar y guiar a la acción inevitable.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative group">
          <div class="mb-8 relative flex items-center">
            <div class="w-12 h-12 rounded-full border border-border-dark bg-surface-dark flex items-center justify-center text-white font-bold font-mono text-lg group-hover:border-primary group-hover:text-primary transition-colors duration-300 relative z-10 shadow-[0_0_15px_rgba(0,0,0,0.5)] group-hover:shadow-[0_0_20px_rgba(34,197,94,0.2)]">
              03
            </div>
            <div class="hidden lg:block h-[1px] w-full bg-border-dark group-hover:bg-primary/50 transition-colors duration-500 origin-left"></div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-display">Desarrollo High-End</h3>
          <p class="text-text-dim text-sm leading-relaxed">
            Código limpio y optimizado, sin constructores lentos. Velocidad de carga extrema (&lt; 1s) para no perder conversiones.
          </p>
        </div>

        <!-- Step 4 -->
        <div class="relative group">
          <div class="mb-8 relative flex items-center">
            <div class="w-12 h-12 rounded-full border border-border-dark bg-surface-dark flex items-center justify-center text-white font-bold font-mono text-lg group-hover:border-primary group-hover:text-primary transition-colors duration-300 relative z-10 shadow-[0_0_15px_rgba(0,0,0,0.5)] group-hover:shadow-[0_0_20px_rgba(34,197,94,0.2)]">
              04
            </div>
            <div class="hidden lg:block h-[1px] w-full bg-transparent"></div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-display">Medición Constante</h3>
          <p class="text-text-dim text-sm leading-relaxed">
            Configuramos métricas de conversión. Tu activo digital nace optimizado pero evoluciona con datos reales.
          </p>
        </div>

      </div>
    </div>
  </div>
</section>
