---
import BigBlob from "./BigBlob.astro";
---

<section id="vsl" class="block vsl-wrap">
  <BigBlob
    size={540}
    parallax={0.16}
    rotate="60deg"
    flip
    style="position:absolute;right:-190px;top:-70px;opacity:.5;filter:blur(1px);z-index:0"
  />
  <div class="vsl-grid">
    <div class="vsl-head">
      <div class="kicker reveal">En 90 segundos</div>
      <h2 class="reveal d1" style="margin-top:14px;font-size:clamp(32px,3.6vw,50px);line-height:1.04">
        Mirá cómo convierto<br /><span class="hl">tráfico en clientes.</span>
      </h2>
      <p class="reveal d2" style="margin-top:22px;max-width:380px;font-size:15.5px">
        Un recorrido corto por mi forma de pensar cada landing: del mensaje a la
        conversión, sin vueltas.
      </p>
      <div class="note vsl-note reveal d3">
        <span class="tape sm" style="top:-10px;left:18px;transform:rotate(-9deg)"></span>
        <p>Dale play ▶<br />después seguimos charlando.</p>
      </div>
    </div>

    <div class="vsl-stage reveal d2">
      <div class="vsl-frame" data-no-pencil>
        <div class="vsl-poster">
          <span class="vsl-grain"></span>
          <button class="vsl-play magnet" type="button" aria-label="Reproducir video de presentación">
            <svg viewBox="0 0 24 24" width="30" height="30" fill="currentColor" aria-hidden="true"><path d="M8 5.5v13l11-6.5z" /></svg>
          </button>
          <span class="vsl-time">02:14</span>
        </div>
        <span class="tape xl" style="top:-15px;left:38%;transform:rotate(-3deg)"></span>
        <span class="tape lg" style="bottom:-13px;right:40px;transform:rotate(6deg)"></span>
        <span class="vsl-badge">VSL · Cómo funciona</span>
      </div>
    </div>
  </div>
</section>
