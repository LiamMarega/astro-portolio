---
import BigBlob from "./BigBlob.astro";
---

<section id="contacto" class="final">
  <BigBlob size={420} parallax={0.2} rotate="210deg" flip style="position:absolute;left:-170px;bottom:-40px;opacity:.9;z-index:0" />
  <h2 class="reveal">
    Convertí tu tráfico en <span class="hl">oportunidades reales.</span>
  </h2>
  <p class="sub reveal d1">
    Si estás listo para una landing que trabaje por vos 24/7, hablemos.
  </p>
  <div class="actions reveal d2">
    <a href="#calificar" class="btn btn-yellow magnet">
      Solicitar diagnóstico
      <span class="arr">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
      </span>
    </a>
    <a href="#calificar" class="btn magnet">
      Ver si califico
      <span class="arr">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
      </span>
    </a>
  </div>
  <ul class="meta reveal d3">
    <li><span class="dot"></span> Respuesta en menos de 24h</li>
    <li><span class="dot"></span> Proyectos desde USD 600</li>
  </ul>
  <div class="side reveal d3">
    Tu próxima conversión<br />empieza con una<br />decisión.
  </div>
</section>
