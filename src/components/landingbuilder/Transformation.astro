---
const deliverables = [
  'Estrategia de conversión',
  'Copy completo de landing',
  'Diseño UI personalizado',
  'Desarrollo responsive',
  'Optimización de velocidad',
  'Formulario de aplicación',
  'Integraciones básicas',
  'Revisión mobile',
  'Entrega del código',
  'Soporte inicial post-lanzamiento',
];
---

<section id="incluye" class="relative bg-background-dark py-20 lg:py-24">
  <div class="absolute inset-0 tech-grid opacity-10"></div>
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <span class="mb-3 block font-mono text-xs uppercase tracking-[0.24em] text-primary">Qué incluye</span>
      <h2 class="font-display text-3xl font-black leading-tight text-white lg:text-5xl">Qué incluye tu Landing Performance Sprint</h2>
      <p class="mt-5 text-lg leading-8 text-zinc-300">No es una plantilla maquillada. Es una landing construida alrededor de tu oferta, tu cliente y el objetivo comercial que querés mover.</p>
    </div>

    <div class="mt-12 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
      {deliverables.map((item) => (
        <div class="flex min-h-28 items-start gap-3 border border-border-dark bg-surface-dark p-5 transition-all hover:border-primary/50">
          <span class="mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-primary text-xs font-black text-black">✓</span>
          <p class="font-medium leading-6 text-white">{item}</p>
        </div>
      ))}
    </div>
  </div>
</section>
