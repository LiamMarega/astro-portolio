---

---

<section
  class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 bg-background-dark overflow-hidden flex flex-col justify-center min-h-[90vh]"
>
  <!-- Ambient Space Grid Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-[500px] h-[500px] rounded-full bg-primary/20 blur-[120px] mix-blend-screen animate-pulse-slow pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-[600px] h-[600px] rounded-full bg-blue-900/20 blur-[130px] mix-blend-screen animate-pulse-slow pointer-events-none" style="animation-delay: 2s;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <!-- Left Column -->
      <div class="lb-hero-content lg:col-span-7 space-y-10 text-left relative">
        <div
          class="inline-flex items-center space-x-3 bg-surface-dark border border-border-dark px-4 py-2 rounded-sm relative"
        >
          <span class="flex h-2 w-2 relative">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"
            ></span>
          </span>
          <span class="text-xs font-mono tracking-wide text-text-dim uppercase"
            >Disponible Q4 2024</span
          >
        </div>

        <h1
          class="text-5xl lg:text-7xl font-bold text-white leading-[1.1] tracking-tight font-display relative z-10"
        >
          Desarrollo de <br class="hidden lg:block" />
          <span class="text-nowrap">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-white ">activos digitales</span> que </span>  <br />
          <span class="relative inline-block px-2 mx-1 z-10 mt-2">
            <span class="relative z-10 text-black">multiplican tu ROI</span>
            <span
              class="absolute inset-0 bg-primary -rotate-2 transform -z-10 skew-x-3 rounded-sm"
            ></span>
            <!-- Handdrawn annotation -->
            <svg class="absolute -bottom-6 -right-8 w-24 h-auto text-white transform rotate-12" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10,50 Q40,20 90,30" />
              <path d="M70,10 L90,30 L70,50" />
            </svg>
          </span>
        </h1>

        <p class="text-lg text-text-dim max-w-xl leading-relaxed font-normal relative z-10">
          Para coaches, marcas personales y negocios digitales que buscan
          escalar. Tu web no debe ser solo un folleto, debe ser una <span
            class="text-white font-medium border-b-2 border-primary/50 pb-0.5">máquina de conversión</span
          >.
        </p>

        <div
          class="flex flex-col sm:flex-row gap-8 pt-6 relative items-center sm:items-start"
        >
          <a
            class="group relative inline-flex items-center justify-center px-8 py-4 border-2 border-primary bg-primary text-black text-lg font-bold shadow-none hover:shadow-brutal-white hover:-translate-y-1 transition-all duration-200 w-full sm:w-auto"
            href="#apply"
          >
            Aplicar para proyecto
            <svg
              class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
            >
          </a>
          <div
            class="flex items-center space-x-4 px-2 py-2 sm:py-0 relative w-full sm:w-auto"
          >
            <div class="flex -space-x-3">
              <div
                class="w-10 h-10 rounded-full bg-surface-dark border border-border-dark flex items-center justify-center text-xs text-text-dim font-bold"
              >
                R
              </div>
              <div
                class="w-10 h-10 rounded-full bg-surface-dark border border-border-dark flex items-center justify-center text-xs text-text-dim font-bold"
              >
                S
              </div>
              <div
                class="w-10 h-10 rounded-full bg-surface-dark border border-border-dark flex items-center justify-center text-xs text-text-dim font-bold"
              >
                M
              </div>
            </div>
            <div class="flex flex-col relative justify-center h-full">
              <span
                class="text-sm text-white font-bold flex items-center gap-1"
              >
                Resultados Reales
                <svg
                  class="w-4 h-4 text-primary"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                  ><path
                    d="M12 1l3.09 6.26L22 8.27l-5 4.87 1.18 6.88L12 16.77l-6.18 3.25L7 13.14 2 8.27l6.91-1.01L12 1z"
                  ></path></svg
                >
              </span>
              <span class="text-xs text-text-dim">En producción</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column (Orbit Animation & Card) -->
      <div class="lg:col-span-5 relative mt-16 lg:mt-0 lg:ml-8 flex justify-center items-center">
        <!-- Custom CSS Orbit Animation -->
        <div class="absolute inset-0 flex items-center justify-center scale-75 sm:scale-100 z-0 opacity-60">
          <div class="relative w-[500px] h-[500px]">
            <!-- Orbit Ring 1 -->
            <div class="absolute inset-0 border border-white/5 rounded-full animate-[spin_60s_linear_infinite]">
              <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 rounded-full overflow-hidden border-2 border-surface-dark bg-background-dark animate-[spin_60s_linear_infinite_reverse]">
                <img src="/images/works/advantis-home.webp" alt="Work 1" class="w-full h-full object-cover grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all" />
              </div>
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-16 h-16 rounded-full overflow-hidden border-2 border-surface-dark bg-background-dark animate-[spin_60s_linear_infinite_reverse]">
                <img src="/images/works/feroxMock.webp" alt="Work 2" class="w-full h-full object-cover grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all" />
              </div>
            </div>
            
            <!-- Orbit Ring 2 -->
            <div class="absolute inset-[60px] border border-white/5 rounded-full animate-[spin_45s_linear_infinite_reverse]">
              <div class="absolute top-1/2 left-0 -translate-x-1/2 -translate-y-1/2 w-14 h-14 rounded-full overflow-hidden border-2 border-surface-dark bg-background-dark animate-[spin_45s_linear_infinite]">
                <img src="/images/works/fmoney.webp" alt="Work 3" class="w-full h-full object-cover grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all" />
              </div>
              <div class="absolute top-1/2 right-0 translate-x-1/2 -translate-y-1/2 w-10 h-10 rounded-full overflow-hidden border-2 border-surface-dark bg-background-dark animate-[spin_45s_linear_infinite]">
                <img src="/images/works/lamshoes.webp" alt="Work 4" class="w-full h-full object-cover grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all" />
              </div>
            </div>
          </div>
        </div>
        <div
          class="relative bg-surface-dark border border-border-dark p-0 shadow-2xl z-10 rounded-sm overflow-hidden transform hover:scale-[1.01] transition-transform duration-500 group"
        >
          <div
            class="bg-surface-dark border-b border-border-dark p-3 flex justify-between items-center"
          >
            <div class="flex space-x-2">
              <div class="w-2.5 h-2.5 rounded-full bg-border-dark"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-border-dark"></div>
            </div>
            <span
              class="font-mono text-[10px] text-text-dim uppercase tracking-wider"
            >
              Growth_Engine_v2.0
            </span>
          </div>
          <div class="p-8 space-y-8 bg-[#0F0F0F] relative">
            <div class="flex items-center justify-between relative z-10 group/header">
              <div class="flex flex-col">
                <span class="text-5xl font-bold text-white font-display group-hover/header:text-primary transition-colors duration-500"
                  >99%</span
                >
                <span
                  class="text-xs text-text-dim uppercase mt-1 tracking-wider"
                  >Performance Score</span
                >
              </div>
              <div
                class="h-14 w-14 rounded-full bg-primary/5 border border-primary/20 flex items-center justify-center relative shadow-[0_0_15px_theme(colors.primary/20%)] animate-[pulse_3s_ease-in-out_infinite]"
              >
                <svg
                  class="w-8 h-8 text-primary animate-[spin_12s_linear_infinite]"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                  ><path
                    d="M9.19 6.35c-2.04 2.29-3.44 5.58-3.57 5.89L2 10.69l4.05-4.05c.47-.47 1.15-.68 1.81-.55l1.33.26zM11.17 17c0 .59-.21 1.18-.62 1.64l-2.72 2.96-1.44-4.98c.31-.13 3.6-1.53 5.89-3.57l-1.11-1.11c-2.29 2.04-5.58 3.44-5.89 3.57L2 10.69l1.35-.84c.31-.23 3.6-1.53 5.89-3.57L11.17 17zm6.48-6.15c.47-.47.68-1.15.55-1.81l-.26-1.33 4.05-4.05-1.55-3.62-5.89 3.57c-2.29 2.04-3.6 1.53-3.57 1.53l1.11 1.11z"
                  ></path></svg
                >
              </div>
            </div>

            <div class="space-y-4">
              <div
                class="bg-background-dark p-4 rounded-sm border border-border-dark flex items-start gap-4 group hover:border-green-500/30 hover:bg-surface-dark transition-all duration-300 cursor-default"
              >
                <div
                  class="bg-green-500/10 p-1.5 rounded-sm text-green-500 mt-1 relative overflow-hidden group-hover:bg-green-500/20 transition-colors"
                >
                  <div class="absolute inset-0 bg-green-500/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"></div>
                  <svg
                    class="w-5 h-5 relative z-10 transform group-hover:scale-110 group-hover:-rotate-12 transition-transform duration-300"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                    ><path
                      d="M20.38 8.57l-1.23 1.85a8 8 0 01-.22 7.58H5.07A8 8 0 0115.58 6.85l1.85-1.23A10 10 0 003.35 19a2 2 0 001.72 1h13.85a2 2 0 001.74-1 10 10 0 00-.27-10.44zm-9.79 6.84a2 2 0 002.83 0l5.66-8.49-8.49 5.66a2 2 0 000 2.83z"
                    ></path></svg
                  >
                </div>
                <div>
                  <div class="text-white font-bold text-sm group-hover:text-green-400 transition-colors duration-300">
                    Carga Instantánea = Menos Rebote y Más Ventas
                  </div>
                  <div class="text-text-dim text-xs mt-1">
                    Cada <span class="text-white">100ms</span> de retraso reduce conversiones un 7%.
                  </div>
                </div>
              </div>
              <div
                class="bg-background-dark p-4 rounded-sm border border-border-dark flex items-start gap-4 group hover:border-blue-500/30 hover:bg-surface-dark transition-all duration-300 cursor-default"
              >
                <div class="bg-blue-500/10 p-1.5 rounded-sm text-blue-500 mt-1 relative overflow-hidden group-hover:bg-blue-500/20 transition-colors">
                  <div class="absolute inset-0 bg-blue-500/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"></div>
                  <svg
                    class="w-5 h-5 relative z-10 transform group-hover:scale-110 group-hover:-translate-y-0.5 transition-transform duration-300"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                    ><path
                      d="M4 6h18V4H4c-1.1 0-2 .9-2 2v11H0v3h14v-3H4V6zm19 2h-6c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h6c.55 0 1-.45 1-1V9c0-.55-.45-1-1-1zm-1 9h-4v-7h4v7z"
                    ></path></svg
                  >
                </div>
                <div>
                  <div class="text-white font-bold text-sm group-hover:text-blue-400 transition-colors duration-300">
                    100% Responsive & Mobile First
                  </div>
                  <div class="text-text-dim text-xs mt-1">
                    Experiencia perfecta donde está tu tráfico.
                  </div>
                </div>
              </div>
              <div
                class="bg-background-dark p-4 rounded-sm border border-border-dark flex items-start gap-4 group hover:border-purple-500/30 hover:bg-surface-dark transition-all duration-300 cursor-default"
              >
                <div
                  class="bg-purple-500/10 p-1.5 rounded-sm text-purple-500 mt-1 relative overflow-hidden group-hover:bg-purple-500/20 transition-colors"
                >
                  <div class="absolute inset-0 bg-purple-500/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"></div>
                  <svg
                    class="w-5 h-5 relative z-10 transform group-hover:scale-110 group-hover:rotate-180 transition-transform duration-700 ease-in-out"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                    ><path
                      d="M11.71 17.99A5.993 5.993 0 016 12c0-3.31 2.69-6 6-6 3.22 0 5.84 2.53 5.99 5.71l-2.1-.63a3.999 3.999 0 10-4.56 4.56l.38 1.35zM22 12c0 .3-.01.6-.04.9l-1.97-.59c.01-.1.01-.21.01-.31 0-4.42-3.58-8-8-8S4 7.58 4 12s3.58 8 8 8c.1 0 .21 0 .31-.01l.59 1.97c-.3.03-.6.04-.9.04-5.52 0-10-4.48-10-10S6.48 2 12 2s10 4.48 10 10zm-3.77 4.26L22 15l-4-1-1 4 1.26-3.77 4.27 4.27 1.06-1.06-5.36-1.18z"
                    ></path></svg
                  >
                </div>
                <div>
                  <div class="text-white font-bold text-sm group-hover:text-purple-400 transition-colors duration-300">
                    Diseño Persuasivo
                  </div>
                  <div class="text-text-dim text-xs mt-1">
                    Estructura enfocada en ventas, no en adornos.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div
          class="absolute -top-6 -right-6 w-32 h-32 bg-primary/10 blur-3xl rounded-full z-0"
        >
        </div>
      </div>
    </div>
  </div>
  <div class="torn-paper-bottom"></div>
</section>
