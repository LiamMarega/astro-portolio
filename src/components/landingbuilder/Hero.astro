---
// Precompute the yellow scallop seal path (deterministic).
const cx = 50,
  cy = 50,
  r = 44,
  teeth = 24;
let scallop = "";
for (let i = 0; i < teeth * 2; i++) {
  const ang = (i / (teeth * 2)) * Math.PI * 2;
  const rad = i % 2 === 0 ? r : r - 5;
  const x = cx + Math.cos(ang) * rad;
  const y = cy + Math.sin(ang) * rad;
  scallop += (i === 0 ? "M" : "L") + x.toFixed(2) + " " + y.toFixed(2);
}
scallop += "Z";
---

<section class="hero">
  <div>
    <p class="hero-handwrite reveal">
      Más que diseño, <span class="u">estrategia que genera oportunidades.</span>
    </p>
    <h1 class="reveal d1">
      Landing pages de alto rendimiento<br />
      para coaches, consultores y<br />
      marcas personales que quieren<br />
      convertir tráfico en <span class="hl">clientes reales.</span>
    </h1>
    <p class="lead reveal d2">
      Diseño, copy y desarrollo web a medida para profesionales y negocios
      digitales que invierten en tráfico pago y orgánico y necesitan
      resultados medibles, no solo una página bonita.
    </p>
    <div class="actions reveal d3">
      <a href="#calificar" class="btn btn-yellow magnet">
        Solicitar diagnóstico gratis
        <span class="arr">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
        </span>
      </a>
      <a href="#vsl" class="btn magnet">Ver cómo trabajo · 90s</a>
    </div>
    <ul class="meta reveal d4">
      <li><span class="dot"></span> Sin compromiso</li>
      <li><span class="dot"></span> Respuesta en &lt;24h</li>
      <li><span class="dot"></span> Proyectos desde USD 600</li>
    </ul>
  </div>

  <div class="collage reveal d2">
    <div class="photo-card" data-hero="photo">
      <div class="backing"></div>
      <div class="frame">
        <img
          src="/images/uploads/liam.jpg"
          width="500"
          height="560"
          alt="Liam, desarrollador detrás de LiamDev"
          fetchpriority="high"
          decoding="async"
        />
      </div>
      <span class="tape xl" style="top:-14px;left:30%;transform:rotate(-3deg)"></span>
      <span class="tape lg" style="top:36px;right:-22px;transform:rotate(72deg)"></span>
      <span class="tape sm" style="top:55%;left:-18px;transform:rotate(85deg)"></span>
    </div>

    <div class="note note-usd" data-hero="usd">
      <span class="tape sm" style="top:-12px;left:50%;transform:translateX(-50%) rotate(-5deg)"></span>
      <div class="desde">Desde</div>
      <div class="amt">USD 600</div>
      <div class="per">por landing</div>
    </div>

    <div class="note alt note-dev" data-hero="dev">
      <span class="tape lg" style="top:-14px;left:22px;transform:rotate(-12deg)"></span>
      <span class="tape sm" style="top:-10px;right:30px;transform:rotate(8deg)"></span>
      <p>
        Desarrollo 100% a cargo mío.<br />
        Sin outsourcing.<br />
        Cupos limitados.
      </p>
    </div>

    <div class="seal" data-hero="seal">
      <svg class="seal-svg" viewBox="0 0 100 100" aria-hidden="true">
        <path d={scallop} fill="#ffe600"></path>
        <circle cx="50" cy="50" r="36" fill="none" stroke="rgba(0,0,0,0.45)" stroke-width="1" stroke-dasharray="2 3"></circle>
      </svg>
      <span class="letter">L.</span>
    </div>

    <div class="particles" aria-hidden="true">
      <span class="particle" style="top:70%;left:-4%;--r:-12deg;--dx:12px;--dy:-18px;animation-delay:-2s"></span>
      <span class="particle" style="top:8%;left:20%;--r:8deg;--dx:-10px;--dy:10px;animation-delay:-6s;opacity:.3"></span>
    </div>
  </div>

  <a class="hero-cue" href="#vsl" aria-label="Seguir bajando">
    <span class="hc-hand">el cuaderno sigue</span>
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4v16M5 13l7 7 7-7" /></svg>
  </a>
</section>
