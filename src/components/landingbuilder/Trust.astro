---
const items = [
  {
    label: "Coaches",
    path: '<path d="M16 5v22M9 27h14M11 10l-5 9h10zM21 10l-5 9h10z" /><circle cx="16" cy="5" r="1.2" />',
  },
  {
    label: "Consultores",
    path: '<path d="M13 8a4 4 0 0 0-4 4v1a3 3 0 0 0-1 5.6V20a4 4 0 0 0 5 4M19 8a4 4 0 0 1 4 4v1a3 3 0 0 1 1 5.6V20a4 4 0 0 1-5 4M16 6v22" />',
  },
  {
    label: "Marcas Personales",
    path: '<circle cx="16" cy="16" r="4" /><path d="M16 4v8M16 20v8M4 16h8M20 16h8" />',
  },
  {
    label: "Infoproductores",
    path: '<rect x="6" y="9" width="20" height="15" rx="1.5" /><path d="M9 9V5h14v4M10 14h12M10 18h8" />',
  },
  {
    label: "SaaS",
    path: '<circle cx="7" cy="9" r="2.4" /><circle cx="25" cy="9" r="2.4" /><circle cx="16" cy="23" r="2.4" /><circle cx="16" cy="6" r="2.4" /><path d="M16 8.4v12.2M9 10.5l5.5 11M23 10.5l-5.5 11" />',
  },
  {
    label: "E-commerce",
    path: '<path d="M4 6h3.5l3 14h13l2-9.5H10" /><circle cx="12" cy="26" r="1.8" /><circle cx="22" cy="26" r="1.8" />',
  },
];
---

<div class="trust reveal">
  <div class="label">Confían en mi trabajo</div>
  <ul>
    {items.map((it) => (
      <li>
        <svg viewBox="0 0 32 32" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={it.path} />
        <span>{it.label}</span>
      </li>
    ))}
  </ul>
</div>
