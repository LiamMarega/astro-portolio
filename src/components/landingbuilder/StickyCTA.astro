---
/* Barra CTA pegajosa (mobile) + nota flotante (desktop) tras scrollear. */
---

<div id="stickyCta" class="sticky-cta" data-no-pencil>
  <span class="sc-txt">¿Listo para convertir más?</span>
  <a href="#calificar" class="btn btn-yellow">
    Quiero mi diagnóstico
    <span class="arr">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
    </span>
  </a>
</div>

<a id="floatNote" class="float-note" href="#calificar" data-no-pencil aria-label="Ir al diagnóstico gratuito">
  <span class="tape sm" style="top:-10px;left:50%;transform:translateX(-50%) rotate(-6deg)"></span>
  <span class="fn-hand">¿Hablamos de<br />tu landing?</span>
  <span class="fn-cta">Diagnóstico gratis →</span>
</a>
