---

<header class="flex flex-col items-center text-center mb-10 mt-4">
  <!-- Avatar -->
  <div class="relative mb-5">
    <div
      class="absolute inset-0 rounded-full bg-[#E2FF00]/20 blur-2xl scale-150"
    >
    </div>
    <img
      src={avatar}
      alt={`${name} — avatar`}
      width="96"
      height="96"
      loading="eager"
      decoding="async"
      class="relative w-24 h-24 rounded-full object-cover border-2 border-white/10 shadow-[0_0_30px_rgba(226,255,0,0.15)]"
    />
  </div>

  <!-- Name -->
  <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-white mb-1">
    {name}
  </h1>

  <!-- Tagline -->
  <p
    class="text-sm sm:text-base text-white/50 font-light tracking-wide animate-pulse-soft"
  >
    {tagline}
  </p>

  <!-- Social strip -->
  <nav aria-label="Redes sociales" class="flex items-center gap-4 mt-5">
    {
      socials.map((s) => (
        <a
          href={s.url}
          target={s.url.startsWith("http") ? "_blank" : undefined}
          rel={s.url.startsWith("http") ? "noopener noreferrer" : undefined}
          aria-label={s.label}
          class="cursor-target w-10 h-10 flex items-center justify-center rounded-full border border-white/10 text-white/50 hover:text-[#E2FF00] hover:border-[#E2FF00]/40 transition-all duration-200 hover:shadow-[0_0_12px_rgba(226,255,0,0.2)]"
        >
          <Fragment set:html={s.icon} />
        </a>
      ))
    }
  </nav>
</header>

<style>
  @keyframes pulse-soft {
    0%,
    100% {
      opacity: 0.5;
    }
    50% {
      opacity: 0.8;
    }
  }
  .animate-pulse-soft {
    animation: pulse-soft 4s ease-in-out infinite;
  }
</style>
