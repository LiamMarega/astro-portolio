---
import Layout from "../../../layouts/LandingBuilderLayout.astro";
import Footer from "../../../components/landingbuilder/Footer.astro";
import { ARTICULOS } from "../../../data/articulos";

const site = "https://www.liammarega.com";
const fechaCorta = (iso: string) =>
  new Date(iso).toLocaleDateString("es-AR", { month: "short", year: "numeric" });

const blogLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Cuaderno de conversión — LiamDev",
  description:
    "Artículos sobre landing pages, conversión, CRO y desarrollo web profesional.",
  url: `${site}/landing-builder/articulos`,
  inLanguage: "es",
  author: { "@type": "Person", name: "Liam Marega", url: site },
  blogPost: ARTICULOS.map((a) => ({
    "@type": "BlogPosting",
    headline: a.title,
    url: `${site}/landing-builder/articulos/${a.slug}`,
    datePublished: a.date,
  })),
};
---

<Layout
  title="Artículos sobre Landing Pages, Conversión y Desarrollo Web | LiamDev"
  description="Guías prácticas sobre cómo crear landing pages que convierten, precios reales, CRO, velocidad web y cómo contratar un desarrollador. Por Liam Marega."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(blogLd)} />

  <header class="nav" id="top">
    <a class="logo" href="/landing-builder" aria-label="LiamDev — inicio">LiamDev</a>
    <nav aria-label="Navegación principal">
      <ul>
        <li><a href="/landing-builder#servicios">Servicios</a></li>
        <li><a href="/landing-builder#proceso">Proceso</a></li>
        <li><a href="/landing-builder#resultados">Resultados</a></li>
      </ul>
    </nav>
    <a href="/landing-builder#calificar" class="btn btn-yellow nav-cta" style="padding:10px 18px;font-size:11.5px">
      Diagnóstico gratis
    </a>
  </header>

  <section class="art-hero">
    <div class="kicker">Cuaderno de conversión</div>
    <h1>
      Notas sobre landings<br />que <span class="hl">venden de verdad.</span>
    </h1>
    <p class="lead">
      Todo lo que aprendí construyendo páginas de alta conversión: estructura,
      copy, velocidad, precios y datos. Sin humo, con ejemplos.
    </p>
  </section>

  <div class="art-grid">
    {ARTICULOS.map((a) => (
      <a class="art-card" href={`/landing-builder/articulos/${a.slug}`}>
        <span class="ac-cat">{a.category}</span>
        <h2>{a.title}</h2>
        <p>{a.excerpt}</p>
        <span class="ac-meta">
          <span>{fechaCorta(a.date)}</span>
          <span>{a.reading} min</span>
        </span>
        <span class="ac-read">leer la nota →</span>
      </a>
    ))}
  </div>

  <Footer />
</Layout>
