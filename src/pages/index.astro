---
import LinktreeLayout from "../layouts/LinktreeLayout.astro";
import LinktreeHero from "../components/linktree/LinktreeHero.astro";
import LinktreeGrid from "../components/linktree/LinktreeGrid.astro";
import TargetCursor from "../components/ui/TargetCursor";

const cards = [
  {
    title: "Portfolio",
    url: "/portfolio",
    icon: "◈",
    description: "Proyectos y trabajos recientes",
    featured: false,
  },
  {
    title: "LANDINGPRO",
    url: "/landing-builder",
    icon: "⚡",
    description: "Landings que convierten a $1000+",
    featured: true,
    badge: "OPEN",
  },
  {
    title: "Newspaper",
    url: "/newspaper",
    icon: "✦",
    description: "Editorial & contenido",
    featured: false,
    badge: "PRÓXIMO",
  },
  {
    title: "Gallery",
    url: "/gallery",
    icon: "▣",
    description: "Visual & diseño",
    featured: false,
  },
  {
    title: "Instagram",
    url: "https://instagram.com/liammarega",
    icon: "IG",
    featured: false,
    external: true,
  },
  {
    title: "YouTube",
    url: "https://youtube.com/@liammarega",
    icon: "YT",
    featured: false,
    external: true,
  },
  {
    title: "GitHub",
    url: "https://github.com/liammarega",
    icon: "GH",
    featured: false,
    external: true,
  },
  {
    title: "Email",
    url: "mailto:liammaregadevelop@gmail.com",
    icon: "@",
    description: "liammaregadevelop@gmail.com",
    featured: false,
  },
];
---

<LinktreeLayout
  title="Liam Marega — Links | Frontend Developer & Digital Strategist"
  description="Hub central de Liam Marega. Portfolio, LANDINGPRO, Newspaper, Gallery y todas mis redes en un solo lugar."
>
  <TargetCursor client:only="react" color="#E2FF00" />

  <main class="relative z-10 min-h-screen flex flex-col items-center px-4 py-14 sm:py-20">
    <LinktreeHero />
    <LinktreeGrid cards={cards} />

    <footer class="mt-12 text-center">
      <p class="text-xs text-white/20 tracking-widest uppercase">
        liammarega.dev · {new Date().getFullYear()}
      </p>
    </footer>
  </main>
</LinktreeLayout>
