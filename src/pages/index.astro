---
import LinktreeLayout from "../layouts/LinktreeLayout.astro";
import LinktreeHero from "../components/linktree/LinktreeHero.astro";
import LinktreeGrid from "../components/linktree/LinktreeGrid.astro";
import TargetCursor from "../components/ui/TargetCursor";

interface Project {
  title: string;
  url: string;
  icon: string;
  description?: string;
  featured?: boolean;
  badge?: string;
  image?: boolean;
  external?: boolean;
  disabled?: boolean;
}

const workingOn: Project[] = [
  {
    title: "SwipeLoop",
    url: "https://swipeloop.app",
    icon: "/images/icons/swipeloop/icon.png",
    description: "Crea carruseles con IA para redes",
    featured: true,
    badge: "IN PROGRESS",
    image: true,
  },
];

const cards: Project[] = [
  {
    title: "Portfolio",
    url: "/portfolio",
    icon: "◈",
    description: "Proyectos y trabajos recientes",
    featured: false,
  },
  // {
  //   title: "LANDINGPRO",
  //   url: "/landing-builder",
  //   icon: "⚡",
  //   description: "Landings que convierten a $1000+",
  //   featured: true,
  //   badge: "OPEN",
  // },
  
  {
    title: "Instagram",
    url: "https://instagram.com/liammdev",
    icon: "IG",
    featured: false,
    external: true,
  },
  {
    title: "YouTube",
    url: "https://youtube.com/@liammdev",
    icon: "YT",
    featured: false,
    external: true,
  },
  {
    title: "GitHub",
    url: "https://github.com/liammarega",
    icon: "GH",
    featured: false,
    external: true,
  },
  {
    title: "Email",
    url: "mailto:liammaregadevelop@gmail.com,liammarega85@gmail.com",
    icon: "@",
    description: "liammaregadevelop@gmail.com",
    featured: false,
  },
  {
    title: "Gallery",
    url: "/gallery",
    icon: "▣",
    description: "Visual & diseño",
    featured: false,
    disabled: true,
  },
  {
    title: "Newspaper",
    url: "/newspaper",
    icon: "✦",
    description: "Editorial & contenido",
    featured: false,
    disabled: true,
  },
];
---

<LinktreeLayout
  title="Liam Marega — Links | Frontend Developer & Digital Strategist"
  description="Hub central de Liam Marega. Portfolio, LANDINGPRO, Newspaper, Gallery y todas mis redes en un solo lugar."
>
  <TargetCursor client:only="react" color="#E2FF00" />

  <main
    class="relative z-10 min-h-screen flex flex-col items-center px-4 py-14 sm:py-20"
  >
    <LinktreeHero />

    <!-- Working on Section -->
    <section class="w-full max-w-lg mb-6">
      <p class="text-xs font-bold uppercase tracking-widest text-white/30 mb-3 ml-1">
        Working on
      </p>
      <nav aria-label="Proyectos en desarrollo" class="grid grid-cols-1 gap-3">
        {workingOn.map((project) => {
          const isExternal = project.url.startsWith("http");
          const isDisabled = project.disabled;

          if (isDisabled) {
            return (
              <div
                aria-label={`${project.title} - Coming soon`}
                class="relative flex items-center gap-4 p-4 rounded-xl border border-white/10 bg-white/5 backdrop-blur-sm cursor-not-allowed opacity-40"
              >
                <!-- Icon -->
                {project.image ? (
                  <img
                    src={project.icon}
                    alt={`${project.title} icon`}
                    width="48"
                    height="48"
                    class="w-12 h-12 rounded-lg object-cover border border-white/10"
                  />
                ) : (
                  <span class="text-2xl text-white/40" aria-hidden="true">
                    {project.icon}
                  </span>
                )}

                <!-- Content -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <p class="font-bold text-base text-white/50 truncate">
                      {project.title}
                    </p>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-white/40 bg-white/10 px-2 py-0.5 rounded-full">
                      COMING SOON
                    </span>
                  </div>
                  <p class="text-xs text-white/30 truncate">
                    {project.description}
                  </p>
                </div>
              </div>
            );
          }

          return (
            <a
              href={project.url}
              target={isExternal ? "_blank" : undefined}
              rel={isExternal ? "noopener noreferrer" : undefined}
              data-cursor-scale
              aria-label={project.title}
              class:list={[
                "cursor-target group relative flex items-center gap-4 p-4 rounded-xl border border-[#E2FF00]/30 bg-[#E2FF00]/5 backdrop-blur-sm",
                "hover:border-[#E2FF00]/60 hover:bg-[#E2FF00]/10 hover:shadow-[0_0_32px_rgba(226,255,0,0.15)]",
                "transition-all duration-300 ease-out hover:-translate-y-0.5",
                "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#E2FF00]/60",
                "animate-glow-pulse"
              ]}
            >
              <!-- Glow effect behind -->
              <div class="absolute inset-0 rounded-xl bg-[#E2FF00]/5 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" />

              <!-- Icon -->
              {project.image ? (
                <img
                  src={project.icon}
                  alt={`${project.title} icon`}
                  width="48"
                  height="48"
                  class="w-12 h-12 rounded-lg object-cover border border-white/10"
                />
              ) : (
                <span class="text-2xl text-[#E2FF00]" aria-hidden="true">
                  {project.icon}
                </span>
              )}

              <!-- Content -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <p class="font-bold text-base text-white truncate">
                    {project.title}
                  </p>
                  {project.badge && (
                    <span class="text-[9px] font-bold uppercase tracking-widest text-[#E2FF00] bg-[#E2FF00]/10 px-2 py-0.5 rounded-full animate-pulse">
                      {project.badge}
                    </span>
                  )}
                </div>
                <p class="text-xs text-white/50 truncate">
                  {project.description}
                </p>
              </div>

              <!-- Arrow -->
              <svg
                class="w-5 h-5 text-[#E2FF00]/60 group-hover:text-[#E2FF00] group-hover:translate-x-0.5 transition-all duration-200"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
              >
                <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          );
        })}
      </nav>
    </section>

    <LinktreeGrid cards={cards} />

    <footer class="mt-12 text-center">
      <p class="text-xs text-white/20 tracking-widest uppercase">
        liammarega.com · {new Date().getFullYear()}
      </p>
    </footer>
  </main>
</LinktreeLayout>
