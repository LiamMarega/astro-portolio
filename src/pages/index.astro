---
import LinktreeLayout from "../layouts/LinktreeLayout.astro";
import LinktreeHero from "../components/linktree/LinktreeHero.astro";
import LinktreeGrid from "../components/linktree/LinktreeGrid.astro";
import SectionHeader from "../components/linktree/SectionHeader.astro";
import LandingProCard from "../components/linktree/LandingProCard.astro";
import ProjectsPreview from "../components/linktree/ProjectsPreview.astro";
import TargetCursor from "../components/ui/TargetCursor";

interface Project {
  title: string;
  url: string;
  icon: string;
  description?: string;
  featured?: boolean;
  badge?: string;
  image?: boolean;
  external?: boolean;
  disabled?: boolean;
}

// Builder — apps propias en desarrollo
const builder: Project[] = [
  {
    title: "SwipeLoop",
    url: "https://swipeloop.app",
    icon: "/images/icons/swipeloop/icon.png",
    description: "Crea carruseles con IA para redes",
    featured: true,
    badge: "IN PROGRESS",
    image: true,
  },
];

// Creador — todas mis redes
const socials: Project[] = [
  {
    title: "Instagram",
    url: "https://instagram.com/liammdev",
    icon: "IG",
    description: "Contenido & detrás de escena",
    external: true,
  },
  {
    title: "YouTube",
    url: "https://youtube.com/@liammdev",
    icon: "YT",
    description: "Tutoriales & builds",
    external: true,
  },
  {
    title: "GitHub",
    url: "https://github.com/liammarega",
    icon: "GH",
    description: "Código & open source",
    external: true,
  },
  {
    title: "Email",
    url: "mailto:liammaregadevelop@gmail.com,liammarega85@gmail.com",
    icon: "@",
    description: "liammaregadevelop@gmail.com",
  },
];
---

<LinktreeLayout
  title="Liam Marega — Links | Frontend Developer & Digital Strategist"
  description="Hub central de Liam Marega. Sistema Landing PRO, proyectos, apps y todas mis redes en un solo lugar."
>
  <TargetCursor client:only="react" color="#E2FF00" />

  <main
    class="relative z-10 min-h-[100dvh] flex flex-col items-center gap-12 px-4 py-14 sm:py-20"
  >
    <LinktreeHero />

    <!-- Sistema Landing PRO — oferta para clientes -->
    <section class="w-full flex flex-col items-center">
      <SectionHeader
        title="Sistema Landing PRO"
        meta="Para clientes que necesitan una landing que convierte"
      />
      <LandingProCard />
    </section>

    <!-- Proyectos — credibilidad para empresas -->
    <section class="w-full flex flex-col items-center">
      <SectionHeader
        title="Proyectos"
        meta="Trabajos para empresas y startups"
        href="/portfolio"
        cta="Ver todos"
      />
      <ProjectsPreview />
    </section>

    <!-- Builder — apps propias -->
    <section class="w-full flex flex-col items-center">
      <SectionHeader title="Builder" meta="Apps que estoy construyendo" />
      <nav
        aria-label="Apps en desarrollo"
        class="w-full max-w-lg grid grid-cols-1 gap-3"
        data-reveal
      >
        {
          builder.map((project) => {
            const isExternal = project.url.startsWith("http");
            return (
              <a
                href={project.url}
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
                data-cursor-scale
                aria-label={project.title}
                class="cursor-target group relative flex items-center gap-4 overflow-hidden rounded-xl border border-white/10 bg-white/[0.02] p-4 ring-1 ring-inset ring-white/5 shadow-[0_10px_30px_-14px_rgba(0,0,0,0.6)] transition-all duration-300 ease-out hover:-translate-y-0.5 hover:border-[#E2FF00]/40 hover:shadow-[0_16px_44px_-14px_rgba(226,255,0,0.18)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#E2FF00]/60"
              >
                <div
                  class="pointer-events-none absolute -right-10 -top-10 h-28 w-28 rounded-full bg-[#E2FF00]/10 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                  aria-hidden="true"
                />

                {project.image ? (
                  <img
                    src={project.icon}
                    alt={`${project.title} icon`}
                    width="48"
                    height="48"
                    class="relative h-12 w-12 rounded-lg object-cover border border-white/10"
                  />
                ) : (
                  <span class="relative text-2xl text-[#E2FF00]" aria-hidden="true">
                    {project.icon}
                  </span>
                )}

                <div class="relative flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <p class="font-bold text-base text-white truncate">
                      {project.title}
                    </p>
                    {project.badge && (
                      <span class="text-[9px] font-bold uppercase tracking-[0.15em] text-[#E2FF00] bg-[#E2FF00]/10 border border-[#E2FF00]/20 px-2 py-0.5 rounded-full">
                        {project.badge}
                      </span>
                    )}
                  </div>
                  <p class="text-xs text-white/50 truncate">
                    {project.description}
                  </p>
                </div>

                <svg
                  class="relative w-5 h-5 text-[#E2FF00]/60 group-hover:text-[#E2FF00] group-hover:translate-x-0.5 transition-all duration-200"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M4 10h12M12 6l4 4-4 4"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            );
          })
        }
      </nav>
    </section>

    <!-- Redes — el creador -->
    <section class="w-full flex flex-col items-center">
      <SectionHeader title="Redes" meta="Seguime y conectemos" />
      <LinktreeGrid cards={socials} />
    </section>

    <footer class="mt-4 text-center">
      <p class="text-xs text-white/20 tracking-widest uppercase">
        liammarega.com · {new Date().getFullYear()}
      </p>
    </footer>
  </main>
</LinktreeLayout>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    // Hero intro on load
    gsap.from("[data-hero]", {
      y: 24,
      autoAlpha: 0,
      duration: 0.8,
      ease: "power3.out",
      stagger: 0.08,
    });

    // Section reveals on scroll
    gsap.utils.toArray<HTMLElement>("[data-reveal]").forEach((el) => {
      gsap.from(el, {
        y: 32,
        autoAlpha: 0,
        duration: 0.7,
        ease: "power3.out",
        scrollTrigger: {
          trigger: el,
          start: "top bottom-=60",
          once: true,
        },
      });
    });
  });
</script>
